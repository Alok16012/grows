generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String           @id @default(uuid())
  name                     String
  email                    String           @unique
  password                 String
  role                     Role             @default(CLIENT)
  phone                    String?
  image                    String?
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  companyId                String?
  assignmentsAsAssigner    Assignment[]     @relation("AssignmentAssigner")
  assignmentsAsInspector   Assignment[]     @relation("AssignmentInspector")
  inspections              Inspection[]
  company                  Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  managedProjects          ProjectManager[] @relation("ProjectManagers")
  assignedProjects         ProjectManager[] @relation("ProjectManagerAssigner")
  notifications            Notification[]
  leadsAssigned            Lead[]           @relation("LeadAssignee")
  leadsCreated             Lead[]           @relation("LeadCreator")
  leadActivities           LeadActivity[]   @relation("LeadActivityUser")
}

model Company {
  id            String    @id @default(uuid())
  name          String
  address       String?
  contactPerson String?
  contactPhone  String?
  logoUrl       String?
  createdBy     String
  createdAt     DateTime  @default(now())
  projects      Project[]
  clients       User[]
  branches      Branch[]
}

model Project {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  description     String?
  createdBy       String
  createdAt       DateTime         @default(now())
  assignments     Assignment[]
  formTemplates   FormTemplate[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectManagers ProjectManager[]
  defectColumns   Json?
  reportConfig    Json?
  alertConfig     AlertConfig?
}

model Assignment {
  id              String       @id @default(uuid())
  projectId       String
  inspectionBoyId String
  assignedBy      String
  status           String       @default("active")
  recurrenceType   String       @default("none")
  recurrenceActive Boolean      @default(false)
  createdAt        DateTime     @default(now())
  assigner         User         @relation("AssignmentAssigner", fields: [assignedBy], references: [id])
  inspectionBoy    User         @relation("AssignmentInspector", fields: [inspectionBoyId], references: [id])
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspections      Inspection[]

  @@index([inspectionBoyId])
  @@index([projectId])
  @@index([status])
}

model Inspection {
  id             String           @id @default(uuid())
  assignmentId   String
  status         String           @default("draft")
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  reviewerNotes  String?
  submittedBy    String
  paperFormPhoto String?
  sentBackAt     DateTime?
  sentBackCount  Int              @default(0)
  gpsLocation    String?
  startedAt      DateTime?
  signature      String?
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submitter      User             @relation(fields: [submittedBy], references: [id])
  responses      InspectionData[]
  shareableLink  ShareableLink?

  @@index([status])
  @@index([assignmentId])
  @@index([submittedBy])
  @@index([submittedAt])
  @@index([approvedAt])
}

model InspectionData {
  id           String       @id @default(uuid())
  inspectionId String
  fieldId      String
  value        String?
  field        FormTemplate @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  inspection   Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([fieldId])
}

model FormTemplate {
  id           String           @id @default(uuid())
  projectId    String
  fieldLabel   String
  fieldType    String
  options      String?
  defaultValue String?
  isRequired   Boolean          @default(false)
  category     String           @default("FIXED")
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses    InspectionData[]

  @@index([projectId])
}

model ProjectManager {
  id         String   @id @default(uuid())
  projectId  String
  managerId  String
  assignedBy String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manager    User     @relation("ProjectManagers", fields: [managerId], references: [id])
  assigner   User     @relation("ProjectManagerAssigner", fields: [assignedBy], references: [id])

  @@unique([projectId, managerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ShareableLink {
  id           String     @id @default(uuid())
  inspectionId String     @unique
  token        String     @unique @default(uuid())
  expiresAt    DateTime?
  createdBy    String
  viewCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AlertConfig {
  id              String   @id @default(uuid())
  projectId       String   @unique
  defectThreshold Float    @default(5.0)
  notifyManager   Boolean  @default(true)
  notifyAdmin     Boolean  @default(true)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  INSPECTION_BOY
  CLIENT
}

enum LeadStatus {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  SELECTED
  ONBOARDED
  REJECTED
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

model Lead {
  id             String        @id @default(uuid())
  candidateName  String
  phone          String
  email          String?
  city           String?
  position       String        // Role applied for e.g. Inspector, Security Guard, Supervisor
  experience     Float?        // Years of experience
  currentCompany String?       // Previous/current employer
  qualification  String?       // 10th, 12th, Graduate, ITI, Diploma, etc.
  skills         String?       // Driving License, Forklift, First Aid, etc.
  expectedSalary Float?
  currentSalary  Float?
  interviewDate  DateTime?
  interviewMode  String?       // In-person, Phone, Video
  source         String        // Walk-in, LinkedIn, Naukri, Referral, WhatsApp, Agency, Indeed
  status         LeadStatus    @default(APPLIED)
  priority       LeadPriority  @default(MEDIUM)
  assignedTo     String?
  notes          String?
  nextFollowUp   DateTime?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  assignee       User?         @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User          @relation("LeadCreator", fields: [createdBy], references: [id])
  activities     LeadActivity[]

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  type      String   // note, call, email, meeting, whatsapp, status_change
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation("LeadActivityUser", fields: [userId], references: [id])

  @@index([leadId])
}

// ─── HELPDESK / TICKETING ─────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String         @id @default(uuid())
  ticketNo    String         @unique
  title       String
  description String
  category    String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  raisedBy    String
  assignedTo  String?
  employeeId  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  dueDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  comments    TicketComment[]

  @@index([status])
  @@index([raisedBy])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Branch {
  id          String       @id @default(uuid())
  name        String
  address     String?
  city        String?
  state       String?
  companyId   String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  employees   Employee[]
  sites       Site[]
}

model Department {
  id          String     @id @default(uuid())
  name        String
  description String?
  branchId    String
  headId      String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  branch      Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees   Employee[]
}

model Site {
  id          String       @id @default(uuid())
  name        String
  address     String?
  city        String?
  branchId    String
  latitude    Float?
  longitude   Float?
  radius      Float        @default(100)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  branch      Branch       @relation(fields: [branchId], references: [id])
  deployments Deployment[]
  attendances Attendance[]
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

model Employee {
  id                String             @id @default(uuid())
  employeeId        String             @unique
  firstName         String
  lastName          String
  email             String?
  phone             String
  alternatePhone    String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  aadharNumber      String?
  panNumber         String?
  bankAccountNumber String?
  bankIFSC          String?
  bankName          String?
  photo             String?
  designation       String?
  departmentId      String?
  branchId          String
  dateOfJoining     DateTime?
  dateOfLeaving     DateTime?
  status            EmployeeStatus     @default(ACTIVE)
  employmentType    String             @default("Full-time")
  salaryType        String?
  basicSalary       Float              @default(0)
  managerId         String?
  notes             String?
  createdBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  branch            Branch             @relation(fields: [branchId], references: [id])
  department        Department?        @relation(fields: [departmentId], references: [id])
  deployments       Deployment[]
  attendances       Attendance[]
  leaves            Leave[]
  payrolls          Payroll[]
  assets            EmployeeAsset[]
  documents         EmployeeDocument[]
  onboardingRecord  OnboardingRecord?
  onboardingTasks   OnboardingTask[]
  reviews           PerformanceReview[]
  exitRequest       ExitRequest?

  @@index([branchId])
  @@index([status])
}

model EmployeeDocument {
  id         String   @id @default(uuid())
  employeeId String
  type       String
  fileName   String
  fileUrl    String
  uploadedAt DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Deployment {
  id         String    @id @default(uuid())
  employeeId String
  siteId     String
  startDate  DateTime
  endDate    DateTime?
  shift      String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  employee   Employee  @relation(fields: [employeeId], references: [id])
  site       Site      @relation(fields: [siteId], references: [id])

  @@index([employeeId])
  @@index([siteId])
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  siteId      String?
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  checkInLat  Float?
  checkInLng  Float?
  checkOutLat Float?
  checkOutLng Float?
  status      String    @default("PRESENT")
  overtimeHrs Float     @default(0)
  workingHrs  Float     @default(0)
  remarks     String?
  markedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])
  site        Site?     @relation(fields: [siteId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

model Leave {
  id              String      @id @default(uuid())
  employeeId      String
  type            String
  startDate       DateTime
  endDate         DateTime
  days            Float
  reason          String?
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model SalaryStructure {
  id            String   @id @default(uuid())
  name          String
  basicPercent  Float    @default(50)
  hraPercent    Float    @default(20)
  pfEmployee    Float    @default(12)
  pfEmployer    Float    @default(12)
  esiEmployee   Float    @default(0.75)
  esiEmployer   Float    @default(3.25)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Payroll {
  id              String        @id @default(uuid())
  employeeId      String
  month           Int
  year            Int
  basicSalary     Float
  hra             Float         @default(0)
  allowances      Float         @default(0)
  overtimePay     Float         @default(0)
  grossSalary     Float
  pfEmployee      Float         @default(0)
  pfEmployer      Float         @default(0)
  esiEmployee     Float         @default(0)
  esiEmployer     Float         @default(0)
  tds             Float         @default(0)
  otherDeductions Float         @default(0)
  totalDeductions Float         @default(0)
  netSalary       Float
  workingDays     Int           @default(26)
  presentDays     Int           @default(26)
  leaveDays       Int           @default(0)
  lwpDays         Float         @default(0)
  overtimeHrs     Float         @default(0)
  overtimeRate    Float         @default(0)
  status          PayrollStatus @default(DRAFT)
  processedAt     DateTime?
  processedBy     String?
  paidAt          DateTime?
  paidBy          String?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  employee        Employee      @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
  @@index([employeeId])
}

model Asset {
  id           String          @id @default(uuid())
  name         String
  category     String
  serialNo     String?
  totalQty     Int             @default(1)
  availableQty Int             @default(1)
  createdAt    DateTime        @default(now())
  assignments  EmployeeAsset[]
}

model EmployeeAsset {
  id         String    @id @default(uuid())
  employeeId String
  assetId    String
  issuedAt   DateTime  @default(now())
  returnedAt DateTime?
  remarks    String?
  employee   Employee  @relation(fields: [employeeId], references: [id])
  asset      Asset     @relation(fields: [assetId], references: [id])

  @@index([employeeId])
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model OnboardingRecord {
  id          String           @id @default(uuid())
  employeeId  String           @unique
  status      OnboardingStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  assignedTo  String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tasks       OnboardingTask[]
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
}

model OnboardingTask {
  id           String           @id @default(uuid())
  onboardingId String
  employeeId   String
  title        String
  description  String?
  category     String
  status       TaskStatus       @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  completedBy  String?
  assignedTo   String?
  order        Int              @default(0)
  isRequired   Boolean          @default(true)
  createdAt    DateTime         @default(now())
  onboarding   OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@index([employeeId])
  @@index([status])
}

model OnboardingChecklist {
  id          String   @id @default(uuid())
  name        String
  description String?
  tasks       Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── PERFORMANCE MANAGEMENT ───────────────────────────────────────────────────

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  CLOSED
}

model PerformanceReview {
  id             String       @id @default(uuid())
  employeeId     String
  reviewerId     String
  period         String
  reviewType     String       @default("QUARTERLY")
  kpis           Json
  totalScore     Float        @default(0)
  rating         String?
  strengths      String?
  improvements   String?
  goals          String?
  status         ReviewStatus @default(DRAFT)
  submittedAt    DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  employee       Employee     @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([period])
}

// ─── EXIT MANAGEMENT ──────────────────────────────────────────────────────────

enum ExitStatus {
  RESIGNATION_SUBMITTED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  FNF_PROCESSING
  COMPLETED
  ABSCONDING
}

model ExitRequest {
  id                String     @id @default(uuid())
  employeeId        String     @unique
  reason            String
  lastWorkingDate   DateTime?
  noticePeriodDays  Int        @default(30)
  status            ExitStatus @default(RESIGNATION_SUBMITTED)
  resignationLetter String?
  interviewNotes    String?
  clearanceItems    Json
  fnfAmount         Float?
  fnfStatus         String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  employee          Employee   @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
}

// ─── BILLING / INVOICING ──────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique   // INV-2024-0001
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientGST     String?
  companyId     String?
  billingMonth  Int           // 1-12
  billingYear   Int
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  subtotal      Float         @default(0)
  taxRate       Float         @default(18)  // GST %
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payments      Payment[]

  @@index([status])
  @@index([billingMonth, billingYear])
  @@index([createdAt])
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String
  description   String
  employeeCount Int     @default(1)
  ratePerHead   Float
  days          Int     @default(26)
  amount        Float
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Float
  paymentDate   DateTime
  paymentMode   String   // Cash, Cheque, NEFT, RTGS, UPI
  referenceNo   String?
  remarks       String?
  recordedBy    String
  createdAt     DateTime @default(now())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── EXPENSE MANAGEMENT ───────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  FUEL
  OFFICE_SUPPLIES
  COMMUNICATION
  MEDICAL
  UNIFORM
  TRAINING
  OTHER
}

model Expense {
  id              String          @id @default(uuid())
  expenseNo       String          @unique   // EXP-0001
  title           String
  category        ExpenseCategory
  amount          Float
  date            DateTime
  description     String?
  receiptUrl      String?         // file upload URL
  submittedBy     String          // userId
  employeeId      String?         // optional: on behalf of employee
  approvedBy      String?         // userId
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  paymentMode     String?         // Cash, NEFT, etc.
  status          ExpenseStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([submittedBy])
  @@index([date])
}

// ─── CLIENT & CONTRACT MANAGEMENT ─────────────────────────────────────────────

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum ContractType {
  FIXED_TERM
  ONGOING
  PROJECT_BASED
  RETAINER
}

model ClientContract {
  id               String         @id @default(uuid())
  contractNo       String         @unique   // CTR-0001
  clientName       String
  clientCompanyId  String?        // optional link to existing Company
  contactPerson    String?
  contactEmail     String?
  contactPhone     String?
  contractType     ContractType   @default(FIXED_TERM)
  status           ContractStatus @default(DRAFT)
  startDate        DateTime
  endDate          DateTime?
  value            Float?         // total contract value
  monthlyValue     Float?         // monthly billing amount
  manpowerCount    Int?           // number of employees to deploy
  serviceType      String?        // Security, Housekeeping, Facility Mgmt, etc.
  slaTerms         String?        // SLA description
  billingCycle     String?        // Monthly, Bi-monthly, etc.
  paymentTerms     String?        // Net 30, Net 15, etc.
  notes            String?
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  renewals         ContractRenewal[]

  @@index([status])
  @@index([clientName])
  @@index([startDate])
}

model ContractRenewal {
  id           String         @id @default(uuid())
  contractId   String
  renewedAt    DateTime       @default(now())
  newEndDate   DateTime
  newValue     Float?
  notes        String?
  renewedBy    String
  contract     ClientContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}
