generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String           @id @default(uuid())
  name                     String
  email                    String           @unique
  password                 String
  role                     Role             @default(CLIENT)
  phone                    String?
  image                    String?
  isActive                 Boolean          @default(true)
  createdAt                DateTime         @default(now())
  companyId                String?
  customRoleId             String?
  assignmentsAsAssigner    Assignment[]     @relation("AssignmentAssigner")
  assignmentsAsInspector   Assignment[]     @relation("AssignmentInspector")
  inspections              Inspection[]
  company                  Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customRole               CustomRole?      @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  managedProjects          ProjectManager[] @relation("ProjectManagers")
  assignedProjects         ProjectManager[] @relation("ProjectManagerAssigner")
  notifications            Notification[]
  leadsAssigned            Lead[]           @relation("LeadAssignee")
  leadsCreated             Lead[]           @relation("LeadCreator")
  leadActivities           LeadActivity[]   @relation("LeadActivityUser")
  leadDocsUploaded         LeadDocument[]   @relation("LeadDocUploader")
  leadFollowUpsCreated     LeadFollowUp[]   @relation("LeadFollowUpCreator")
  leadFormsCreated         LeadForm[]       @relation("LeadFormCreator")
  hrApprovedReviews        PerformanceReview[] @relation("HRApprover")
  employeeProfile          Employee?           @relation("EmployeeUser")
}

model CustomRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[]
  color       String   @default("#6366f1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Company {
  id            String    @id @default(uuid())
  name          String
  address       String?
  contactPerson String?
  contactPhone  String?
  logoUrl       String?
  createdBy     String
  createdAt     DateTime  @default(now())
  projects      Project[]
  clients       User[]
  branches      Branch[]
}

model Project {
  id              String           @id @default(uuid())
  companyId       String
  name            String
  description     String?
  createdBy       String
  createdAt       DateTime         @default(now())
  assignments     Assignment[]
  formTemplates   FormTemplate[]
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectManagers ProjectManager[]
  defectColumns   Json?
  reportConfig    Json?
  alertConfig     AlertConfig?
}

model Assignment {
  id              String       @id @default(uuid())
  projectId       String
  inspectionBoyId String
  assignedBy      String
  status           String       @default("active")
  recurrenceType   String       @default("none")
  recurrenceActive Boolean      @default(false)
  createdAt        DateTime     @default(now())
  assigner         User         @relation("AssignmentAssigner", fields: [assignedBy], references: [id])
  inspectionBoy    User         @relation("AssignmentInspector", fields: [inspectionBoyId], references: [id])
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspections      Inspection[]

  @@index([inspectionBoyId])
  @@index([projectId])
  @@index([status])
}

model Inspection {
  id             String           @id @default(uuid())
  assignmentId   String
  status         String           @default("draft")
  submittedAt    DateTime?
  createdAt      DateTime         @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  reviewerNotes  String?
  submittedBy    String
  paperFormPhoto String?
  sentBackAt     DateTime?
  sentBackCount  Int              @default(0)
  gpsLocation    String?
  startedAt      DateTime?
  signature      String?
  assignment     Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  submitter      User             @relation(fields: [submittedBy], references: [id])
  responses      InspectionData[]
  shareableLink  ShareableLink?

  @@index([status])
  @@index([assignmentId])
  @@index([submittedBy])
  @@index([submittedAt])
  @@index([approvedAt])
}

model InspectionData {
  id           String       @id @default(uuid())
  inspectionId String
  fieldId      String
  value        String?
  field        FormTemplate @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  inspection   Inspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([fieldId])
}

model FormTemplate {
  id           String           @id @default(uuid())
  projectId    String
  fieldLabel   String
  fieldType    String
  options      String?
  defaultValue String?
  isRequired   Boolean          @default(false)
  category     String           @default("FIXED")
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responses    InspectionData[]

  @@index([projectId])
}

model ProjectManager {
  id         String   @id @default(uuid())
  projectId  String
  managerId  String
  assignedBy String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manager    User     @relation("ProjectManagers", fields: [managerId], references: [id])
  assigner   User     @relation("ProjectManagerAssigner", fields: [assignedBy], references: [id])

  @@unique([projectId, managerId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ShareableLink {
  id           String     @id @default(uuid())
  inspectionId String     @unique
  token        String     @unique @default(uuid())
  expiresAt    DateTime?
  createdBy    String
  viewCount    Int        @default(0)
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([token])
}

model AlertConfig {
  id              String   @id @default(uuid())
  projectId       String   @unique
  defectThreshold Float    @default(5.0)
  notifyManager   Boolean  @default(true)
  notifyAdmin     Boolean  @default(true)
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  MANAGER
  HR_MANAGER
  INSPECTION_BOY
  CLIENT
}

enum LeadStatus {
  NEW_LEAD
  CONTACTED
  INTERESTED
  INTERVIEW_SCHEDULED
  INTERVIEW_DONE
  SELECTED
  OFFERED
  JOINED
  REJECTED
  DROPPED
}

enum LeadScore {
  HOT
  WARM
  COLD
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

model Lead {
  id                String        @id @default(uuid())
  candidateName     String
  phone             String
  email             String?
  city              String?
  position          String        // Role applied for e.g. Inspector, Security Guard, Supervisor
  experience        Float?        // Years of experience
  currentCompany    String?       // Previous/current employer
  qualification     String?       // 10th, 12th, Graduate, ITI, Diploma, etc.
  skills            String?       // Driving License, Forklift, First Aid, etc.
  expectedSalary    Float?
  currentSalary     Float?
  interviewDate     DateTime?
  interviewMode     String?       // In-person, Phone, Video
  source            String        // Walk-in, LinkedIn, Naukri, Referral, WhatsApp, Agency, Indeed
  status            LeadStatus    @default(NEW_LEAD)
  priority          LeadPriority  @default(MEDIUM)
  score             LeadScore     @default(WARM)
  interviewerId     String?
  interviewFeedback String?
  interviewResult   String?       // PASS / FAIL / HOLD
  assignedTo        String?
  notes             String?
  nextFollowUp      DateTime?
  locality          String?       // Area/locality within city (WorkIndia "Location")
  gender            String?       // Male/Female/Other
  languages         String?       // Known languages
  age               Int?          // Candidate age
  course            String?       // BE/BTech/MBA etc
  specialization    String?       // Mechanical/CS/HR etc
  collegeName       String?       // College/University name
  courseStartYear   String?       // e.g. "2015-4"
  courseEndYear     String?       // e.g. "2019-4"
  previousDesignation String?     // Previous job title
  previousCompany   String?       // Previous company name (separate from currentCompany)
  resumeUrl         String?       // Direct resume download link
  profileUrl        String?       // WorkIndia/LinkedIn profile URL
  englishLevel      String?       // Good English / Basic English / No English
  levelOfExperience String?       // Fresher / Experienced
  // Conversion tracking
  convertedEmployeeId String?     // Set when lead is converted to employee
  formSlug          String?       // Which public form was used (if any)
  siteId            String?       // Target site for deployment after joining
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  assignee          User?         @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator           User          @relation("LeadCreator", fields: [createdBy], references: [id])
  site              Site?         @relation("LeadSite", fields: [siteId], references: [id], onDelete: SetNull)
  activities        LeadActivity[]
  documents         LeadDocument[]
  followUps         LeadFollowUp[]

  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
}

model LeadForm {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  siteId      String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation("LeadFormCreator", fields: [createdBy], references: [id])
  site        Site?    @relation("LeadFormSite", fields: [siteId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([isActive])
}

model LeadDocument {
  id         String   @id @default(uuid())
  leadId     String
  docType    String   // RESUME, AADHAAR, PAN, CERTIFICATE, OTHER
  fileName   String
  url        String
  verified   String   @default("PENDING") // PENDING / APPROVED / REJECTED
  uploadedBy String
  createdAt  DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploader   User     @relation("LeadDocUploader", fields: [uploadedBy], references: [id])
  @@index([leadId])
}

model LeadFollowUp {
  id          String   @id @default(uuid())
  leadId      String
  type        String   // CALL / INTERVIEW / DOCUMENT / OTHER
  note        String?
  scheduledAt DateTime
  completedAt DateTime?
  status      String   @default("PENDING") // PENDING / DONE / SNOOZED
  createdBy   String
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator     User     @relation("LeadFollowUpCreator", fields: [createdBy], references: [id])
  @@index([leadId])
  @@index([scheduledAt])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  type      String   // note, call, email, meeting, whatsapp, status_change
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation("LeadActivityUser", fields: [userId], references: [id])

  @@index([leadId])
}

// ─── HELPDESK / TICKETING ─────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String         @id @default(uuid())
  ticketNo    String         @unique
  title       String
  description String
  category    String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  raisedBy    String
  assignedTo  String?
  employeeId  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  dueDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  comments    TicketComment[]

  @@index([status])
  @@index([raisedBy])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  userId     String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Branch {
  id          String       @id @default(uuid())
  name        String
  address     String?
  city        String?
  state       String?
  companyId   String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  employees   Employee[]
  sites       Site[]
}

model Department {
  id          String     @id @default(uuid())
  name        String
  description String?
  branchId    String
  headId      String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  branch      Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees   Employee[]
}

model Site {
  id               String       @id @default(uuid())
  name             String
  code             String?      @unique
  address          String
  city             String?
  state            String?
  pincode          String?
  clientName       String?
  clientId         String?
  branchId         String
  latitude         Float?
  longitude        Float?
  radius           Float        @default(100)
  manpowerRequired Int          @default(1)
  contactPerson    String?
  contactPhone     String?
  siteType         String?
  shift            String?
  isActive         Boolean      @default(true)
  createdBy        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  branch           Branch       @relation(fields: [branchId], references: [id])
  deployments      Deployment[]
  attendances      Attendance[]
  leads            Lead[]       @relation("LeadSite")
  leadForms        LeadForm[]   @relation("LeadFormSite")

  @@index([isActive])
  @@index([clientId])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
  ONBOARDING
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

model Employee {
  id                String             @id @default(uuid())
  employeeId        String             @unique
  firstName         String
  lastName          String
  email             String?
  phone             String
  alternatePhone    String?
  dateOfBirth       DateTime?
  gender            String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  aadharNumber      String?
  panNumber         String?
  bankAccountNumber String?
  bankIFSC          String?
  bankName          String?
  photo             String?
  designation       String?
  departmentId      String?
  branchId          String?
  dateOfJoining     DateTime?
  dateOfLeaving     DateTime?
  status            EmployeeStatus     @default(ACTIVE)
  employmentType    String             @default("Full-time")
  salaryType        String?
  basicSalary       Float              @default(0)
  managerId         String?
  notes             String?
  isKycVerified     Boolean            @default(false)
  kycRejectionNote  String?
  isHandicap        Boolean            @default(false)
  onboardingToken   String?            @unique
  userId            String?            @unique
  createdBy         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Identity
  middleName            String?
  nameAsPerAadhar       String?
  fathersName           String?
  bloodGroup            String?
  maritalStatus         String?
  marriageDate          DateTime?
  nationality           String?   @default("Indian")
  religion              String?
  caste                 String?

  // Statutory Numbers
  uan                   String?
  pfNumber              String?
  esiNumber             String?
  labourCardNo          String?
  labourCardExpDate     DateTime?

  // Contract Details
  contractFrom          DateTime?
  contractPeriodDays    Int?
  contractorCode        String?
  workOrderNumber       String?
  workOrderFrom         DateTime?
  workOrderTo           DateTime?
  workSkill             String?
  natureOfWork          String?
  categoryCode          String?
  employmentTypeCode    String?

  // Emergency Contacts
  emergencyContact1Name  String?
  emergencyContact1Phone String?
  emergencyContact2Name  String?
  emergencyContact2Phone String?

  // Permanent Address
  permanentAddress      String?
  permanentCity         String?
  permanentState        String?
  permanentPincode      String?

  // Background & Medical
  isBackgroundChecked   Boolean   @default(false)
  backgroundCheckRemark String?
  isMedicalDone         Boolean   @default(false)
  medicalRemark         String?

  // Safety Equipment Issued
  safetyGoggles         Boolean   @default(false)
  safetyGogglesDate     DateTime?
  safetyGloves          Boolean   @default(false)
  safetyGlovesDate      DateTime?
  safetyHelmet          Boolean   @default(false)
  safetyHelmetDate      DateTime?
  safetyMask            Boolean   @default(false)
  safetyMaskDate        DateTime?
  safetyJacket          Boolean   @default(false)
  safetyJacketDate      DateTime?
  safetyEarMuffs        Boolean   @default(false)
  safetyEarMuffsDate    DateTime?
  safetyShoes           Boolean   @default(false)
  safetyShoesDate       DateTime?

  // Bank extra
  bankBranch            String?
  user              User?              @relation("EmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  branch            Branch?            @relation(fields: [branchId], references: [id])
  department        Department?        @relation(fields: [departmentId], references: [id])
  deployments       Deployment[]
  attendances       Attendance[]
  leaves            Leave[]
  payrolls          Payroll[]
  assets            EmployeeAsset[]
  documents         EmployeeDocument[]
  onboardingRecord  OnboardingRecord?
  onboardingTasks   OnboardingTask[]
  reviews           PerformanceReview[]
  pips              PIP[]
  exitRequest       ExitRequest?
  enrollments       CourseEnrollment[]
  fieldTasks        FieldTask[]
  checkIns          FieldCheckIn[]
  policyAcknowledgments PolicyAcknowledgment[]
  iltAttendances   ILTAttendance[]
  courseFeedbacks  CourseFeedback[]
  employeeSalary   EmployeeSalary?
  advances         AdvanceAndReimbursement[]
  hrDocuments      HrDocument[]

  @@index([branchId])
  @@index([status])
}

model EmployeeDocument {
  id              String   @id @default(uuid())
  employeeId      String
  type            String
  fileName        String
  fileUrl         String
  status          String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  rejectionReason String?
  verifiedBy      String?
  uploadedAt      DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeSalary {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  // Core salary components (monthly fixed)
  basic             Float    @default(0)
  da                Float    @default(0)   // Dearness Allowance
  washing           Float    @default(0)   // Washing Allowance
  conveyance        Float    @default(0)   // Conveyance Allowance
  leaveWithWages    Float    @default(0)   // Leave With Wages
  otherAllowance    Float    @default(0)   // Other Allowance
  bonus             Float    @default(583)  // Monthly bonus (manual input, default ₹583 = 7000/12)
  otRatePerHour     Float    @default(170) // OT rate per calculation unit (₹170 default)
  canteenRatePerDay Float    @default(55)  // Canteen rate per day (₹55 default)
  // Legacy/kept fields
  ctcAnnual         Float    @default(0)
  ctcMonthly        Float    @default(0)
  hra               Float    @default(0)   // Auto-calculated: (basic+da)*5%, kept for reference
  specialAllowance  Float    @default(0)
  complianceType    String   @default("OR")  // CALL (no PF/ESIC) or OR (full compliance)
  isPfEligible      Boolean  @default(true)
  isEsiEligible     Boolean  @default(true)
  isPtEligible      Boolean  @default(true)
  lwfState          String?
  serviceChargeRate Float    @default(0)
  status            String   @default("APPROVED") // PROPOSED, APPROVED, REJECTED
  proposedBy        String   @default("system")
  approvedBy        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Deployment {
  id          String    @id @default(uuid())
  employeeId  String
  siteId      String
  startDate   DateTime
  endDate     DateTime?
  shift       String?
  role        String?
  isActive    Boolean   @default(true)
  relievedAt  DateTime?
  notes       String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([siteId])
  @@index([isActive])
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  siteId      String?
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  checkInLat  Float?
  checkInLng  Float?
  checkOutLat Float?
  checkOutLng Float?
  status      String    @default("PRESENT")
  overtimeHrs Float     @default(0)
  workingHrs  Float     @default(0)
  remarks     String?
  markedBy    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])
  site        Site?     @relation(fields: [siteId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

model Leave {
  id              String      @id @default(uuid())
  employeeId      String
  type            String
  startDate       DateTime
  endDate         DateTime
  days            Float
  reason          String?
  status          LeaveStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model SalaryStructure {
  id            String   @id @default(uuid())
  name          String
  basicPercent  Float    @default(50)
  hraPercent    Float    @default(20)
  pfEmployee    Float    @default(12)
  pfEmployer    Float    @default(12)
  esiEmployee   Float    @default(0.75)
  esiEmployer   Float    @default(3.25)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Payroll {
  id              String        @id @default(uuid())
  employeeId      String
  payrollRunId    String?
  month           Int
  year            Int
  // --- Full Month Earnings (Section 1) ---
  basicFull       Float         @default(0)
  daFull          Float         @default(0)
  hraFull         Float         @default(0)
  washingFull     Float         @default(0)
  conveyanceFull  Float         @default(0)
  lwwFull         Float         @default(0)
  bonusFull       Float         @default(0)
  otherFull       Float         @default(0)
  grossFullMonth  Float         @default(0)  // Sum of all full-month components
  // --- Earned/Prorated Earnings (Section 2) ---
  basicSalary     Float         @default(0)  // basicEarned
  da              Float         @default(0)  // daEarned
  hra             Float         @default(0)  // hraEarned
  washing         Float         @default(0)  // washingEarned
  conveyance      Float         @default(0)  // conveyanceEarned
  lwwEarned       Float         @default(0)
  bonus           Float         @default(0)  // bonusEarned
  allowances      Float         @default(0)  // otherEarned
  otDays          Float         @default(0)
  overtimePay     Float         @default(0)  // OT pay
  productionIncentive Float     @default(0)
  grossSalary     Float         @default(0)  // Total gross earned
  // --- Deductions ---
  pfEmployee      Float         @default(0)
  pfEmployer      Float         @default(0)
  esiEmployee     Float         @default(0)
  esiEmployer     Float         @default(0)
  pt              Float         @default(0)
  lwf             Float         @default(0)
  tds             Float         @default(0)
  canteenDays     Int           @default(0)
  canteen         Float         @default(0)
  penalty         Float         @default(0)
  advance         Float         @default(0)
  otherDeductions Float         @default(0)
  totalDeductions Float         @default(0)
  // --- Net & CTC ---
  netSalary       Float         @default(0)
  ctc             Float         @default(0)  // CTC = fullGross + empPF + empESIC
  // --- Attendance ---
  workingDays     Int           @default(26)
  presentDays     Int           @default(26)
  leaveDays       Float         @default(0)
  lwpDays         Float         @default(0)
  overtimeHrs     Float         @default(0)
  overtimeRate    Float         @default(0)
  siteId          String?
  status          PayrollStatus @default(DRAFT)
  processedAt     DateTime?
  processedBy     String?
  paidAt          DateTime?
  paidBy          String?
  remarks         String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  employee        Employee      @relation(fields: [employeeId], references: [id])
  payrollRun      PayrollRun?   @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@unique([employeeId, month, year])
  @@index([month, year])
  @@index([status])
  @@index([employeeId])
  @@index([payrollRunId])
}

model PayrollRun {
  id                String        @id @default(uuid())
  month             Int
  year              Int
  status            PayrollStatus @default(DRAFT)
  lockedAt          DateTime?
  processedBy       String
  totalGross        Float         @default(0)
  totalNet          Float         @default(0)
  totalPfEmployer   Float         @default(0)
  totalEsiEmployer  Float         @default(0)
  totalLwf          Float         @default(0)
  totalTds          Float         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  payrolls          Payroll[]

  @@unique([month, year])
  @@index([status])
}

model StatutoryChallan {
  id              String   @id @default(uuid())
  type            String   // PF, ESI, PT, LWF, TDS
  month           Int
  year            Int
  trrnNumber      String?
  amount          Float
  paymentDate     DateTime?
  status          String   @default("PENDING") // PENDING, PAID, FAILED
  documentUrl     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([type])
  @@index([month, year])
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  DEDUCTED
}

model AdvanceAndReimbursement {
  id              String        @id @default(uuid())
  employeeId      String
  type            String        // ADVANCE, REIMBURSEMENT, UNIFORM_DEDUCTION
  amount          Float
  monthToImpact   Int
  yearToImpact    Int
  reason          String?
  status          AdvanceStatus @default(PENDING)
  approvedBy      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  employee        Employee      @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([monthToImpact, yearToImpact])
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  LOST
}

model Asset {
  id           String         @id @default(uuid())
  assetCode    String         @unique
  name         String
  category     String
  description  String?
  serialNo     String?
  quantity     Int            @default(1)
  available    Int            @default(1)
  condition    AssetCondition @default(NEW)
  purchaseDate DateTime?
  purchaseCost Float?
  vendor       String?
  location     String?
  isActive     Boolean        @default(true)
  createdBy    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  assignments  EmployeeAsset[]

  @@index([category])
  @@index([isActive])
}

model EmployeeAsset {
  id              String          @id @default(uuid())
  employeeId      String
  assetId         String
  issuedAt        DateTime        @default(now())
  issuedBy        String?
  returnedAt      DateTime?
  returnedTo      String?
  condition       AssetCondition  @default(GOOD)
  returnCondition AssetCondition?
  notes           String?
  isActive        Boolean         @default(true)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([assetId])
  @@index([isActive])
}

// ─── ONBOARDING ───────────────────────────────────────────────────────────────

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model OnboardingRecord {
  id          String           @id @default(uuid())
  employeeId  String           @unique
  status      OnboardingStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  assignedTo  String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tasks       OnboardingTask[]
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([status])
}

model OnboardingTask {
  id           String           @id @default(uuid())
  onboardingId String
  employeeId   String
  title        String
  description  String?
  category     String
  status       TaskStatus       @default(PENDING)
  dueDate      DateTime?
  completedAt  DateTime?
  completedBy  String?
  assignedTo   String?
  order        Int              @default(0)
  isRequired   Boolean          @default(true)
  createdAt    DateTime         @default(now())
  onboarding   OnboardingRecord @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@index([employeeId])
  @@index([status])
}

model OnboardingChecklist {
  id          String   @id @default(uuid())
  name        String
  description String?
  tasks       Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ─── PERFORMANCE MANAGEMENT ───────────────────────────────────────────────────

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  COMPLETED
}

enum ReviewCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  ANNUAL
}

model PerformanceReview {
  id                   String       @id @default(uuid())
  employeeId           String
  reviewerId           String
  cycle                ReviewCycle
  periodStart          DateTime
  periodEnd            DateTime
  status               ReviewStatus @default(DRAFT)
  overallRating        Float?
  strengths            String?
  improvements         String?
  managerComments      String?
  employeeComments     String?
  promotionRecommended Boolean      @default(false)
  incrementPercent     Float?
  selfRating           Float?
  selfComments         String?
  hrApprovedAt         DateTime?
  hrApprovedBy         String?
  bonusPercent         Float?
  performanceRank      String?
  incentiveAmount      Float?
  bonusNote            String?
  pipRequired          Boolean      @default(false)
  submittedAt          DateTime?
  acknowledgedAt       DateTime?
  completedAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  employee             Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hrApprover           User?        @relation("HRApprover", fields: [hrApprovedBy], references: [id], onDelete: SetNull)
  kpis                 KPI[]
  kras                 KRA[]
  pip                  PIP?

  @@index([employeeId])
  @@index([status])
  @@index([cycle])
}

model KRA {
  id          String            @id @default(uuid())
  reviewId    String
  title       String
  description String?
  weightage   Float             @default(25)
  kpis        KPI[]
  review      PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model KPI {
  id          String            @id @default(uuid())
  reviewId    String
  kraId       String?
  title       String
  description String?
  target      Float             @default(0)
  actual      Float?            @default(0)
  weightage   Float             @default(10)
  rating      Float?
  remarks     String?
  review      PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  kra         KRA?              @relation(fields: [kraId], references: [id], onDelete: SetNull)

  @@index([reviewId])
  @@index([kraId])
}

model PIP {
  id           String            @id @default(uuid())
  reviewId     String            @unique
  employeeId   String
  startDate    DateTime
  endDate      DateTime
  goals        String
  status       String            @default("ACTIVE")
  managerNotes String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  review       PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  employee     Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model KPITemplate {
  id          String   @id @default(uuid())
  role        String
  kraTitle    String
  kpiTitle    String
  description String?
  targetHint  String?
  weightage   Float    @default(10)
  createdAt   DateTime @default(now())
}

// ─── EXIT MANAGEMENT ──────────────────────────────────────────────────────────

enum ExitType {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
  ABSCONDING
}

enum ExitStatus {
  INITIATED
  NOTICE_PERIOD
  CLEARANCE_PENDING
  FULL_FINAL_PENDING
  COMPLETED
  CANCELLED
}

model ExitRequest {
  id                String     @id @default(uuid())
  employeeId        String     @unique
  exitType          ExitType
  status            ExitStatus @default(INITIATED)
  resignationDate   DateTime
  lastWorkingDate   DateTime?
  noticePeriodDays  Int        @default(30)
  reason            String?
  hrComments        String?
  fnfAmount         Float?
  fnfPaidAt         DateTime?
  fnfPaidBy         String?
  initiatedBy       String
  approvedBy        String?
  approvedAt        DateTime?
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clearanceTasks    ExitClearanceTask[]

  @@index([status])
  @@index([exitType])
}

model ExitClearanceTask {
  id           String      @id @default(uuid())
  exitId       String
  title        String
  department   String
  status       String      @default("PENDING")
  dueDate      DateTime?
  completedAt  DateTime?
  completedBy  String?
  remarks      String?
  order        Int         @default(0)
  exitRequest  ExitRequest @relation(fields: [exitId], references: [id], onDelete: Cascade)

  @@index([exitId])
}

// ─── FIELD WORKFORCE ──────────────────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FieldTaskStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  MISSED
  CANCELLED
}

model FieldTask {
  id            String          @id @default(uuid())
  taskNo        String          @unique   // FT-0001
  title         String
  description   String?
  employeeId    String
  siteId        String?
  priority      TaskPriority    @default(MEDIUM)
  status        FieldTaskStatus @default(ASSIGNED)
  dueDate       DateTime
  dueTime       String?         // "09:00", "18:00" etc
  completedAt   DateTime?
  completedNote String?
  assignedBy    String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([dueDate])
}

model FieldCheckIn {
  id               String    @id @default(uuid())
  employeeId       String
  siteId           String?
  latitude         Float
  longitude        Float
  accuracy         Float?
  checkedInAt      DateTime  @default(now())
  notes            String?
  isGeofenced      Boolean   @default(false)
  distanceFromSite Float?
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([checkedInAt])
}

// ─── LMS ──────────────────────────────────────────────────────────────────────

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
  DROPPED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

model Policy {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String    // SAFETY, HR, COMPLIANCE, SOP
  fileUrl     String?
  isRequired  Boolean   @default(true)
  isActive    Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
  acknowledgments PolicyAcknowledgment[]

  @@index([category])
  @@index([isActive])
}

model PolicyAcknowledgment {
  id           String   @id @default(uuid())
  policyId     String
  employeeId   String
  acknowledgedAt DateTime @default(now())
  ipAddress    String?
  policy       Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([policyId, employeeId])
  @@index([employeeId])
  @@index([policyId])
}

enum ILTStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ILTSession {
  id           String      @id @default(uuid())
  title        String
  description  String?
  instructorId String
  courseId     String?
  location     String?
  startTime    DateTime
  endTime      DateTime
  maxSeats     Int         @default(20)
  status       ILTStatus   @default(SCHEDULED)
  materialsUrl String?
  feedbackForm Json?
  createdBy    String?
  createdAt    DateTime    @default(now())
  attendances  ILTAttendance[]

  @@index([status])
  @@index([instructorId])
  @@index([startTime])
}

model ILTAttendance {
  id          String    @id @default(uuid())
  sessionId   String
  employeeId  String
  attendedAt  DateTime?
  status      String    @default("PENDING") // PENDING, PRESENT, ABSENT, LATE
  feedback    String?
  rating      Int?      // 1-5
  session     ILTSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([sessionId, employeeId])
  @@index([sessionId])
  @@index([employeeId])
}

model Course {
  id           String       @id @default(uuid())
  courseCode   String       @unique
  title        String
  description  String?
  category     String
  duration     Int          @default(60)
  passingScore Int          @default(70)
  isMandatory  Boolean      @default(false)
  status       CourseStatus @default(DRAFT)
  createdBy    String?
  thumbnail    String?
  validityDays Int?         // null = forever, e.g., 365 for 1 year validity
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  modules      CourseModule[]
  quiz         Quiz?
  enrollments  CourseEnrollment[]
  assignmentRules CourseAssignmentRule[]
  feedbacks    CourseFeedback[]

  @@index([status])
  @@index([category])
}

model CourseAssignmentRule {
  id         String   @id @default(uuid())
  courseId   String
  assignTo   String   // ROLE, DESIGNATION, SITE, CLIENT, BRANCH, ALL
  value      String   // e.g., "OPERATOR", "Safety", siteId, clientName, etc.
  dueDays    Int?     // Days from enrollment to complete
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([assignTo])
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  content     String?
  videoUrl    String?
  duration    Int      @default(15)
  order       Int      @default(0)
  isRequired  Boolean  @default(true)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Quiz {
  id           String            @id @default(uuid())
  courseId     String            @unique
  title        String            @default("Course Assessment")
  description  String?
  passingScore Int               @default(70)
  timeLimit    Int?              // in minutes, null = no limit
  maxAttempts  Int               @default(3)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  course       Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@index([courseId])
}

model QuizQuestion {
  id           String       @id @default(uuid())
  quizId       String
  question     String
  questionType QuestionType @default(MULTIPLE_CHOICE)
  options      QuizOption[]
  order        Int          @default(0)
  points       Int          @default(1)
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizOption {
  id         String        @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean       @default(false)
  order      Int           @default(0)
  question   QuizQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id           String       @id @default(uuid())
  quizId       String
  employeeId   String
  score        Float?
  passed       Boolean?
  startedAt    DateTime     @default(now())
  submittedAt  DateTime?
  answers      Json?       // { questionId: optionId }
  quiz         Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([employeeId])
}

model CourseEnrollment {
  id           String           @id @default(uuid())
  courseId     String
  employeeId   String
  enrolledAt   DateTime         @default(now())
  enrolledBy   String?
  startedAt    DateTime?
  completedAt  DateTime?
  dueDate      DateTime?
  score        Float?
  status       EnrollmentStatus @default(ENROLLED)
  attempts     Int              @default(0)
  certificate  String?
  progress     Int              @default(0)
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([courseId, employeeId])
  @@index([employeeId])
  @@index([courseId])
  @@index([status])
}

model CourseFeedback {
  id           String           @id @default(uuid())
  courseId     String
  employeeId   String
  enrollmentId String?
  rating       Int              // 1-5 stars
  comment      String?
  submittedAt  DateTime         @default(now())
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([courseId, employeeId])
  @@index([courseId])
  @@index([employeeId])
}

// ─── BILLING / INVOICING ──────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique   // INV-2024-0001
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientGST     String?
  companyId     String?
  billingMonth  Int           // 1-12
  billingYear   Int
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  subtotal      Float         @default(0)
  taxRate       Float         @default(18)  // GST %
  taxAmount     Float         @default(0)
  totalAmount   Float         @default(0)
  paidAmount    Float         @default(0)
  notes         String?
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payments      Payment[]

  @@index([status])
  @@index([billingMonth, billingYear])
  @@index([createdAt])
}

model InvoiceItem {
  id            String  @id @default(uuid())
  invoiceId     String
  description   String
  employeeCount Int     @default(1)
  ratePerHead   Float
  days          Int     @default(26)
  amount        Float
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  amount        Float
  paymentDate   DateTime
  paymentMode   String   // Cash, Cheque, NEFT, RTGS, UPI
  referenceNo   String?
  remarks       String?
  recordedBy    String
  createdAt     DateTime @default(now())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── EXPENSE MANAGEMENT ───────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  FUEL
  OFFICE_SUPPLIES
  COMMUNICATION
  MEDICAL
  UNIFORM
  TRAINING
  OTHER
}

model Expense {
  id              String          @id @default(uuid())
  expenseNo       String          @unique   // EXP-0001
  title           String
  category        ExpenseCategory
  amount          Float
  date            DateTime
  description     String?
  receiptUrl      String?         // file upload URL
  submittedBy     String          // userId
  employeeId      String?         // optional: on behalf of employee
  approvedBy      String?         // userId
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  paidAt          DateTime?
  paymentMode     String?         // Cash, NEFT, etc.
  status          ExpenseStatus   @default(DRAFT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([submittedBy])
  @@index([date])
}

// ─── CLIENT & CONTRACT MANAGEMENT ─────────────────────────────────────────────

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum ContractType {
  FIXED_TERM
  ONGOING
  PROJECT_BASED
  RETAINER
}

model ClientContract {
  id               String         @id @default(uuid())
  contractNo       String         @unique   // CTR-0001
  clientName       String
  clientCompanyId  String?        // optional link to existing Company
  contactPerson    String?
  contactEmail     String?
  contactPhone     String?
  contractType     ContractType   @default(FIXED_TERM)
  status           ContractStatus @default(DRAFT)
  startDate        DateTime
  endDate          DateTime?
  value            Float?         // total contract value
  monthlyValue     Float?         // monthly billing amount
  manpowerCount    Int?           // number of employees to deploy
  serviceType      String?        // Security, Housekeeping, Facility Mgmt, etc.
  slaTerms         String?        // SLA description
  billingCycle     String?        // Monthly, Bi-monthly, etc.
  paymentTerms     String?        // Net 30, Net 15, etc.
  notes            String?
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  renewals         ContractRenewal[]

  @@index([status])
  @@index([clientName])
  @@index([startDate])
}

model ContractRenewal {
  id           String         @id @default(uuid())
  contractId   String
  renewedAt    DateTime       @default(now())
  newEndDate   DateTime
  newValue     Float?
  notes        String?
  renewedBy    String
  contract     ClientContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model HrDocumentType {
  id               String       @id @default(uuid())
  name             String       @unique
  description      String?
  templateContent  String?      // HTML/text template with {{variables}}
  autoGenerate     Boolean      @default(false)
  requiresApproval Boolean      @default(true)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  documents        HrDocument[]
}

enum HrDocStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ISSUED
}

model HrDocument {
  id             String          @id @default(uuid())
  docNumber      String          @unique // e.g. DOC-2026-0001
  employeeId     String
  typeId         String
  effectiveDate  DateTime?
  content        String          // Filled template content
  status         HrDocStatus     @default(DRAFT)
  remarks        String?
  rejectionNote  String?
  createdBy      String          // userId
  approvedBy     String?         // userId
  issuedBy       String?         // userId
  approvedAt     DateTime?
  issuedAt       DateTime?
  acknowledged   Boolean         @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type           HrDocumentType  @relation(fields: [typeId], references: [id])

  @@index([employeeId])
  @@index([status])
}
